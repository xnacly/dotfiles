# Wayland port of ~/.config/i3/config.
# Start with `sway -c ~/.config/sway/config`; inspect app ids with
# `swaymsg -t get_tree` when a window rule does not match.

set $rosewater #dc8a78
set $flamingo #dd7878
set $pink #ea76cb
set $mauve #8839ef
set $red #d20f39
set $maroon #e64553
set $peach #fe640b
set $yellow #df8e1d
set $green #40a02b
set $teal #179299
set $sky #04a5e5
set $sapphire #209fb5
set $blue #1e66f5
set $lavender #7287fd
set $text #4c4f69
set $subtext1 #5c5f77
set $subtext0 #6c6f85
set $overlay2 #7c7f93
set $overlay1 #8c8fa1
set $overlay0 #9ca0b0
set $surface2 #acb0be
set $surface1 #bcc0cc
set $surface0 #ccd0da
set $base #eff1f5
set $mantle #e6e9ef
set $crust #dce0e8

set $browser firefox
set $term ghostty
set $font Maple Mono NF
set $font_size 14
set $gaps 0
set $mod Mod4
set $alt Mod1

default_border pixel 3
title_align center
hide_edge_borders smart
focus_follows_mouse no
floating_modifier $mod
gaps inner $gaps
font pango:$font $font_size

output * bg ~/.config/wallpapers/tokyonightWallpaper.png fill

input * {
    xkb_layout de
    repeat_delay 250
    repeat_rate 50
}

input type:touchpad {
    tap enabled
}

bindsym $alt+space exec "makoctl dismiss"
bindsym $mod+space focus mode_toggle
bindsym $mod+c exec $term --working-directory="$HOME/.config/sway/"
bindsym $mod+b exec $browser
bindsym $mod+shift+s exec grim -g "$(slurp)" - | wl-copy --type image/png
bindsym $mod+e exec "thunar"
bindsym $mod+n exec "nm-connection-editor"
bindsym $mod+d exec "fuzzel"
bindsym $mod+Return exec $term
bindsym $mod+Shift+q kill
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+space floating toggle
bindsym $mod+t layout tabbed
bindsym $mod+s layout toggle split
bindsym $mod+v bar mode toggle
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r reload
bindsym $mod+Shift+e exec "swaynag -t warning -m 'Exit Sway and end this Wayland session?' -B 'Yes, exit Sway' 'swaymsg exit'"
bindsym $mod+$alt+l exec ~/.config/sway/scripts/lock.sh

bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioRaiseVolume exec --no-startup-id ~/.config/sway/scripts/volume.sh up
bindsym XF86AudioLowerVolume exec --no-startup-id ~/.config/sway/scripts/volume.sh down
bindsym XF86AudioMute exec --no-startup-id ~/.config/sway/scripts/volume.sh toggle
bindsym XF86KbdBrightnessUp exec brightnessctl --device='smc::kbd_backlight' set +10%
bindsym XF86KbdBrightnessDown exec brightnessctl --device='smc::kbd_backlight' set 10%-
bindsym XF86MonBrightnessUp exec brightnessctl set +5%
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

mode "resize" {
        bindsym h resize shrink width 10 px or 10 ppt
        bindsym j resize grow height 10 px or 10 ppt
        bindsym k resize shrink height 10 px or 10 ppt
        bindsym l resize grow width 10 px or 10 ppt
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

# Wayland-native apps match on app_id. XWayland apps may still match on class.
assign [app_id="firefox"] $ws1
assign [class="firefox"] $ws1
assign [app_id="discord"] $ws3
assign [class="discord"] $ws3
for_window [app_id="spotify"] move to workspace $ws4
for_window [class="Spotify"] move to workspace $ws4

for_window [window_role="pop-up"] floating enable
for_window [window_role="bubble"] floating enable
for_window [window_role="task_dialog"] floating enable
for_window [window_role="Preferences"] floating enable
for_window [window_type="dialog"] floating enable
for_window [window_type="menu"] floating enable

# target                 title     bg    text   indicator  border
client.focused           $mauve    $base $text  $mauve     $mauve
client.focused_inactive  $overlay0 $base $text  $rosewater $overlay0
client.unfocused         $overlay0 $base $text  $rosewater $mantle
client.urgent            $peach    $base $peach $overlay0  $peach
client.placeholder       $overlay0 $base $text  $overlay0  $overlay0
client.background        $base

bar {
    bindsym button1 nop
    status_command i3blocks
    position top
    strip_workspace_numbers yes
    colors {
        background         $base
        statusline         $text
        focused_statusline $text
        focused_separator  $base

        # target           border bg        text
        focused_workspace  $base  $mauve    $crust
        active_workspace   $base  $surface2 $text
        inactive_workspace $base  $base     $text
        urgent_workspace   $base  $red      $crust
    }
}

exec --no-startup-id dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway XDG_SESSION_DESKTOP=sway XDG_SESSION_TYPE=wayland
exec --no-startup-id systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP XDG_SESSION_TYPE
exec --no-startup-id /usr/lib/xdg-desktop-portal -r
exec_always --no-startup-id ~/.config/sway/scripts/kanshi.sh
exec --no-startup-id nm-applet --indicator
exec --no-startup-id swayidle -w timeout 300 '~/.config/sway/scripts/lock.sh' timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' before-sleep '~/.config/sway/scripts/lock.sh'
exec_always --no-startup-id "playerctld daemon"
exec --no-startup-id "spotify"
exec --no-startup-id "discord"
exec --no-startup-id "thunar --daemon"
exec --no-startup-id "/usr/lib/xfce-polkit/xfce-polkit"
